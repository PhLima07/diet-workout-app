# Supabase PostgreSQL — Transaction pooler (porta 6543)
# Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# USDA FoodData Central (DEMO_KEY funciona com limites de taxa)
USDA_API_KEY=DEMO_KEY

# ExerciseDB via RapidAPI (opcional — sem chave, Claude usa conhecimento próprio)
RAPIDAPI_KEY=

# CORS — use * para dev, domínio Vercel em produção
ALLOWED_ORIGINS=*
